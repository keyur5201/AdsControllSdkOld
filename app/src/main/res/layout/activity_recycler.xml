<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.adsv2.ads.control.sdk.activity.RecyclerActivity">

    <TextView
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:text="NativeAds In Recyclerview"
        android:fontFamily="@font/font_bold"
        android:textSize="16sp"
        android:gravity="center_vertical"
        android:paddingHorizontal="15dp"
        android:background="@color/primary"
        android:textColor="@color/white" />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/recyclerView"
        android:layout_margin="5dp"
        android:layout_above="@+id/bannerAds"
        android:layout_below="@+id/header" />

    <com.adssdkmanager.ads_manager.ShowNativeAds
        android:id="@+id/bannerAds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:ads_type="ads_banner"/>

</RelativeLayout>